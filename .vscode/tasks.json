{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "esbuild",
      "type": "shell",
      "command": "npm run esbuild",
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "build:webview",
      "type": "shell",
      "command": "yarn build:webview",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "build-all",
      "dependsOn": ["esbuild", "build:webview"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
